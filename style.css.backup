/* MODERN MATRIX DESIGN - 2024 */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');

:root {
    --matrix-green: #00ff41;
    --matrix-dark: #0d0208;
    --matrix-darker: #000000;
    --matrix-light: #00ff4180;
    --glass-bg: rgba(13, 2, 8, 0.7);
    --glass-border: rgba(0, 255, 65, 0.2);
    --shadow-glow: 0 8px 32px rgba(0, 255, 65, 0.15);
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--matrix-darker);
    color: var(--matrix-green);
    overflow: hidden;
    height: 100vh;
    width: 100vw;
}

/* Matrix rain canvas */
#matrix-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0.4;
}

/* Main container - modern grid layout */
.container {
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100vh;
    position: relative;
    z-index: 10;
}

/* Modern header with glassmorphism */
.header {
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--glass-border);
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: var(--shadow-glow);
    position: relative;
    z-index: 100;
}

.logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.ai-icon {
    font-size: 1.75rem;
    animation: iconPulse 3s ease-in-out infinite;
    filter: drop-shadow(0 0 8px var(--matrix-green));
}

@keyframes iconPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.1); opacity: 0.8; }
}

.logo h1 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--matrix-green), #00aa00);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

/* Modern mood indicator */
.mood-indicator {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(0, 255, 65, 0.05);
    padding: 0.5rem 1rem;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(10px);
    transition: var(--transition);
}

.mood-indicator:hover {
    background: rgba(0, 255, 65, 0.1);
    border-color: var(--matrix-green);
}

#mood-emoji {
    font-size: 1.5rem;
    animation: emojiFloat 2s ease-in-out infinite;
}

@keyframes emojiFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
}

#mood-text {
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.mood-btn {
    background: linear-gradient(135deg, rgba(0, 255, 65, 0.1), rgba(0, 170, 0, 0.1));
    border: 1px solid var(--matrix-green);
    padding: 0.5rem 1rem;
    color: var(--matrix-green);
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: var(--transition);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.mood-btn:hover {
    background: var(--matrix-green);
    color: var(--matrix-darker);
    box-shadow: 0 4px 16px rgba(0, 255, 65, 0.4);
    transform: translateY(-2px);
}

/* Main content area - modern 2-column layout */
.main {
    display: grid !important;
    grid-template-columns: 1fr 320px !important;
    gap: 1.5rem;
    padding: 1.5rem;
    overflow: hidden;
    height: calc(100vh - 80px);
}

@media (max-width: 1200px) {
    .main {
        grid-template-columns: 1fr 280px !important;
    }
}

/* Chat container with modern card design */
.chat-container {
    display: flex;
    flex-direction: column;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    overflow: hidden;
    box-shadow: var(--shadow-glow);
}

/* Messages area */
.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.chat-messages::-webkit-scrollbar {
    width: 6px;
}

.chat-messages::-webkit-scrollbar-track {
    background: transparent;
}

.chat-messages::-webkit-scrollbar-thumb {
    background: var(--matrix-light);
    border-radius: 3px;
}

.chat-messages::-webkit-scrollbar-thumb:hover {
    background: var(--matrix-green);
}

/* Modern message bubbles */
.message {
    display: flex;
    gap: 0.75rem;
    max-width: 80%;
    animation: messageSlide 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes messageSlide {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.user-message {
    align-self: flex-end;
    flex-direction: row-reverse;
}

.message-avatar {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
    background: linear-gradient(135deg, rgba(0, 255, 65, 0.2), rgba(0, 170, 0, 0.2));
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(10px);
}

.user-message .message-avatar {
    background: linear-gradient(135deg, rgba(0, 255, 65, 0.3), rgba(0, 200, 50, 0.3));
}

.message-content {
    background: rgba(0, 255, 65, 0.05);
    padding: 1rem 1.25rem;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    font-size: 0.9375rem;
    line-height: 1.6;
    backdrop-filter: blur(10px);
    transition: var(--transition);
}

.message-content:hover {
    background: rgba(0, 255, 65, 0.08);
    border-color: var(--matrix-green);
}

.user-message .message-content {
    background: rgba(0, 255, 65, 0.08);
}

.message-content img {
    max-width: 100%;
    border-radius: 12px;
    margin: 0.75rem 0;
    border: 1px solid var(--glass-border);
}

.message-content ul {
    margin: 0.75rem 0;
    padding-left: 1.5rem;
}

.message-content li {
    margin: 0.5rem 0;
}

.message-content strong {
    color: var(--matrix-green);
    font-weight: 600;
}

/* Modern input area */
.chat-input-container {
    padding: 1.5rem;
    border-top: 1px solid var(--glass-border);
    background: rgba(0, 0, 0, 0.3);
}

.input-wrapper {
    display: flex;
    gap: 0.75rem;
    background: rgba(0, 255, 65, 0.05);
    padding: 0.5rem;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    transition: var(--transition);
}

.input-wrapper:focus-within {
    border-color: var(--matrix-green);
    box-shadow: 0 0 0 3px rgba(0, 255, 65, 0.1);
}

#user-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0.75rem;
    color: var(--matrix-green);
    font-size: 0.9375rem;
    font-family: 'Inter', sans-serif;
    outline: none;
}

#user-input::placeholder {
    color: rgba(0, 255, 65, 0.4);
}

.send-btn {
    width: 44px;
    height: 44px;
    background: var(--matrix-green);
    border: none;
    border-radius: 12px;
    color: var(--matrix-darker);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
    font-size: 1.25rem;
}

.send-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 16px rgba(0, 255, 65, 0.4);
}

.send-btn:active {
    transform: scale(0.95);
}

.input-info {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
}

#char-count {
    font-size: 0.75rem;
    color: rgba(0, 255, 65, 0.5);
    font-family: 'JetBrains Mono', monospace;
}

/* Modern sidebar */
.sidebar {
    display: flex !important;
    flex-direction: column;
    gap: 1rem;
    overflow-y: auto;
    padding-right: 0.5rem;
    height: 100%;
    min-width: 280px;
}

.sidebar::-webkit-scrollbar {
    width: 6px;
}

.sidebar::-webkit-scrollbar-track {
    background: transparent;
}

.sidebar::-webkit-scrollbar-thumb {
    background: var(--matrix-light);
    border-radius: 3px;
}

/* Modern cards */
.quick-actions, .memory-section, .mood-info, .stats {
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    padding: 1.25rem;
    box-shadow: var(--shadow-glow);
    transition: var(--transition);
}

.quick-actions:hover, .memory-section:hover, .mood-info:hover, .stats:hover {
    border-color: var(--matrix-green);
    box-shadow: 0 8px 32px rgba(0, 255, 65, 0.25);
}

.sidebar h3 {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    color: var(--matrix-green);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

/* Modern buttons */
.quick-btn {
    width: 100%;
    background: rgba(0, 255, 65, 0.05);
    border: 1px solid var(--glass-border);
    padding: 0.75rem 1rem;
    color: var(--matrix-green);
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 10px;
    cursor: pointer;
    transition: var(--transition);
    text-align: left;
    margin-bottom: 0.5rem;
}

.quick-btn:last-child {
    margin-bottom: 0;
}

.quick-btn:hover {
    background: rgba(0, 255, 65, 0.1);
    border-color: var(--matrix-green);
    transform: translateX(4px);
}

.quick-btn:active {
    transform: translateX(2px);
}

/* Memory tips */
.memory-tips {
    margin-top: 1rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 10px;
    border-left: 3px solid var(--matrix-green);
}

.memory-tips p {
    font-size: 0.8125rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
}

.memory-tips small {
    font-size: 0.75rem;
    color: rgba(0, 255, 65, 0.6);
    display: block;
    margin-top: 0.25rem;
    font-family: 'JetBrains Mono', monospace;
}

/* Mood display */
.mood-display {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 10px;
    margin-bottom: 1rem;
}

#sidebar-mood-emoji {
    font-size: 2rem;
    animation: emojiFloat 2s ease-in-out infinite;
}

#sidebar-mood-text {
    font-size: 1rem;
    font-weight: 600;
}

.mood-description {
    font-size: 0.8125rem;
    color: rgba(0, 255, 65, 0.7);
    line-height: 1.5;
    margin-top: 0.5rem;
}

/* Stats */
.stat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(0, 255, 65, 0.1);
}

.stat-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
}

.stat-label {
    font-size: 0.8125rem;
    color: rgba(0, 255, 65, 0.7);
}

.stat-value {
    font-size: 1rem;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
}

/* Quick replies */
.quick-replies {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
}

.quick-reply-btn {
    background: rgba(0, 255, 65, 0.08);
    border: 1px solid var(--glass-border);
    padding: 0.5rem 0.875rem;
    color: var(--matrix-green);
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 8px;
    cursor: pointer;
    transition: var(--transition);
}

.quick-reply-btn:hover {
    background: rgba(0, 255, 65, 0.15);
    border-color: var(--matrix-green);
    transform: translateY(-2px);
}

/* Modern export button */
.export-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 56px;
    height: 56px;
    background: var(--matrix-green);
    border: none;
    border-radius: 16px;
    color: var(--matrix-darker);
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
    z-index: 999;
    box-shadow: 0 8px 24px rgba(0, 255, 65, 0.3);
}

.export-btn:hover {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 12px 32px rgba(0, 255, 65, 0.5);
}

.export-btn:active {
    transform: scale(0.95);
}

/* Modern loading */
.loading {
    position: fixed;
    bottom: 6rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    padding: 1rem 1.5rem;
    border-radius: 16px;
    display: flex;
    align-items: center;
    gap: 1rem;
    z-index: 1000;
    box-shadow: var(--shadow-glow);
}

.loading-spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--glass-border);
    border-top-color: var(--matrix-green);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.loading span {
    font-size: 0.875rem;
    font-weight: 500;
}

.hidden {
    display: none !important;
}

/* Responsive design */
@media (max-width: 1024px) {
    .main {
        grid-template-columns: 1fr;
        grid-template-rows: 1fr auto;
    }
    
    .sidebar {
        max-height: 300px;
        flex-direction: row;
        overflow-x: auto;
        padding-bottom: 0.5rem;
    }
    
    .sidebar > * {
        min-width: 280px;
    }
    
    .export-btn {
        bottom: 1rem;
        right: 1rem;
        width: 48px;
        height: 48px;
    }
}

@media (max-width: 640px) {
    .header {
        padding: 1rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .logo h1 {
        font-size: 1.25rem;
    }
    
    .main {
        padding: 1rem;
        gap: 1rem;
    }
    
    .chat-container {
        border-radius: 16px;
    }
    
    .message {
        max-width: 90%;
    }
    
    .mood-indicator {
        order: 3;
        width: 100%;
        justify-content: center;
    }
}

/* Smooth transitions */
* {
    transition: background-color 0.2s ease, border-color 0.2s ease;
}

/* Focus styles */
button:focus-visible,
input:focus-visible {
    outline: 2px solid var(--matrix-green);
    outline-offset: 2px;
}

/* Selection */
::selection {
    background: var(--matrix-green);
    color: var(--matrix-darker);
}


/* ===== NEW FEATURES ===== */

/* 1. Particles effect */
.particle-cursor {
    position: fixed;
    width: 8px;
    height: 8px;
    background: var(--matrix-green);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    animation: particleFade 1s ease-out forwards;
    box-shadow: 0 0 10px var(--matrix-green);
}

@keyframes particleFade {
    0% {
        opacity: 1;
        transform: translate(0, 0) scale(1);
    }
    100% {
        opacity: 0;
        transform: translate(var(--tx), var(--ty)) scale(0);
    }
}

/* 2. Typing indicator */
.typing-indicator {
    display: flex;
    gap: 0.75rem;
    max-width: 80%;
    padding: 1rem;
    animation: messageSlide 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.typing-indicator .message-avatar {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    background: linear-gradient(135deg, rgba(0, 255, 65, 0.2), rgba(0, 170, 0, 0.2));
    border: 1px solid var(--glass-border);
}

.typing-dots {
    background: rgba(0, 255, 65, 0.05);
    padding: 1rem 1.5rem;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    display: flex;
    gap: 0.5rem;
    align-items: center;
}

.typing-dot {
    width: 8px;
    height: 8px;
    background: var(--matrix-green);
    border-radius: 50%;
    animation: typingBounce 1.4s infinite;
}

.typing-dot:nth-child(2) {
    animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
    animation-delay: 0.4s;
}

@keyframes typingBounce {
    0%, 60%, 100% {
        transform: translateY(0);
        opacity: 0.7;
    }
    30% {
        transform: translateY(-10px);
        opacity: 1;
    }
}

/* 3. Message reactions */
.message-wrapper {
    position: relative;
    display: flex;
    gap: 0.75rem;
    max-width: 80%;
}

.message-wrapper.user-message {
    align-self: flex-end;
    flex-direction: row-reverse;
}

.message-actions {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    opacity: 0;
    transition: opacity 0.2s;
}

.message-wrapper:hover .message-actions {
    opacity: 1;
}

.reaction-btn {
    width: 32px;
    height: 32px;
    background: rgba(0, 255, 65, 0.1);
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    font-size: 1rem;
}

.reaction-btn:hover {
    background: rgba(0, 255, 65, 0.2);
    transform: scale(1.1);
}

.message-reactions {
    display: flex;
    gap: 0.25rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
}

.reaction-item {
    background: rgba(0, 255, 65, 0.1);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 0.25rem 0.5rem;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    cursor: pointer;
    transition: var(--transition);
}

.reaction-item:hover {
    background: rgba(0, 255, 65, 0.2);
    transform: scale(1.05);
}

.reaction-count {
    font-size: 0.75rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
}

/* 4. Smooth scroll */
.chat-messages {
    scroll-behavior: smooth;
}

/* 5. Code syntax highlighting */
.message-content pre {
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    margin: 0.75rem 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.5;
}

.message-content code {
    background: rgba(0, 255, 65, 0.1);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    color: var(--matrix-green);
}

.message-content pre code {
    background: transparent;
    padding: 0;
}

/* Code highlighting colors */
.code-keyword { color: #ff79c6; }
.code-string { color: #50fa7b; }
.code-number { color: #bd93f9; }
.code-comment { color: #6272a4; font-style: italic; }
.code-function { color: #8be9fd; }

/* 6. Dark/Light mode toggle */
.theme-toggle {
    position: relative;
    width: 60px;
    height: 32px;
    background: rgba(0, 255, 65, 0.1);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    padding: 0 4px;
}

.theme-toggle:hover {
    background: rgba(0, 255, 65, 0.15);
}

.theme-toggle-slider {
    width: 24px;
    height: 24px;
    background: var(--matrix-green);
    border-radius: 50%;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 255, 65, 0.3);
}

body.light-mode .theme-toggle-slider {
    transform: translateX(28px);
}

/* Light mode styles */
body.light-mode {
    --matrix-green: #00aa00;
    --matrix-dark: #f0f0f0;
    --matrix-darker: #ffffff;
    --matrix-light: #00aa0080;
    --glass-bg: rgba(255, 255, 255, 0.7);
    --glass-border: rgba(0, 170, 0, 0.2);
    --shadow-glow: 0 8px 32px rgba(0, 170, 0, 0.15);
}

body.light-mode {
    background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
    color: #1b5e20;
}

body.light-mode #matrix-canvas {
    opacity: 0.15;
}

body.light-mode .message-content {
    color: #1b5e20;
}

body.light-mode #user-input {
    color: #1b5e20;
}

body.light-mode .send-btn {
    background: #00aa00;
    color: #ffffff;
}

body.light-mode .mood-btn {
    color: #00aa00;
}

body.light-mode .mood-btn:hover {
    background: #00aa00;
    color: #ffffff;
}

/* Reaction picker popup */
.reaction-picker {
    position: absolute;
    bottom: 100%;
    left: 0;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 0.5rem;
    display: flex;
    gap: 0.25rem;
    box-shadow: var(--shadow-glow);
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
    transition: var(--transition);
    z-index: 100;
}

.reaction-picker.active {
    opacity: 1;
    transform: translateY(-10px);
    pointer-events: all;
}

.reaction-option {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    cursor: pointer;
    border-radius: 8px;
    transition: var(--transition);
}

.reaction-option:hover {
    background: rgba(0, 255, 65, 0.2);
    transform: scale(1.2);
}
